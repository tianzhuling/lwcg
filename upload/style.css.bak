:root {
  --main-bg: #f9f9f9;
  --radius: 12px;
  --spacing: 16px;
}

* {
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  margin: 0;
  padding: var(--spacing);
  background-color: var(--main-bg);
}

.container {
  max-width: 600px;
  margin: 2rem auto;
  background: white;
  padding: var(--spacing);
  border-radius: var(--radius);
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
}

h1, h2 {
  text-align: center;
  font-size: 1.5rem;
  margin-bottom: var(--spacing);
}

label {
  display: block;
  margin-bottom: 1rem;
}

input[type="text"],
input[type="file"],
button {
  width: 100%;
  padding: 0.75rem;
  font-size: 1rem;
  margin-top: 0.5rem;
  border: 1px solid #ccc;
  border-radius: var(--radius);
}

button {
  background-color: #2d89ef;
  color: white;
  border: none;
  margin-top: var(--spacing);
  cursor: pointer;
  transition: background-color 0.2s ease;
}

button:hover {
  background-color: #1b6dcf;
}

#status {
  text-align: center;
  margin-top: var(--spacing);
  font-size: 1rem;
  word-break: break-word;
  padding: 0;
  border-radius: var(--radius);
}

#preview,
#browse-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 1rem;
  justify-content: center;
}

#preview img,
#browse-preview img {
  width: 100px;
  height: auto;
  border-radius: 6px;
  object-fit: cover;
  border: 1px solid #ccc;
}

#btn-back {
  display: block;
  margin: 0 auto 24px;
  padding: 8px 16px;
  background: #555;
  color: #fff;
  text-decoration: none;
  border-radius: 12px;
  text-align: center;
}

#upload-progress {
  text-align: center;
  margin-top: 8px;
  font-size: 0.9rem;
  color: #666;
}
